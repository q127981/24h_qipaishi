/* packageA/pages/verifyRecord/verifyRecord.wxss */
page {
  background: #f0f2f5;
}

.container {
  padding: 0;
}

/* ========================
   顶部筛选栏
   ======================== */
.filter-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-bottom: 1rpx solid #eee;
  padding: 0 16rpx;
  height: 88rpx;
}

.filter-left {
  flex-shrink: 0;
  width: 220rpx;
}

.filter-right {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
}

.date-chips {
  display: flex;
  gap: 8rpx;
}

.date-chip {
  padding: 8rpx 16rpx;
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 8rpx;
  line-height: 1;
}

.date-chip.active {
  background: #e8f8ed;
  color: #5aab6e;
  font-weight: 600;
}

/* 下拉菜单样式覆写 */
.van-dropdown-menu {
  height: 60rpx !important;
  border-radius: 50rpx;
  background: transparent !important;
  box-shadow: none !important;
}

.van-dropdown-menu__item {
  justify-content: flex-start !important;
}

.van-dropdown-menu__title {
  width: 100% !important;
  font-size: 28rpx !important;
}

/* ========================
   列表
   ======================== */
.record-list {
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.record-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

/* 第一行：标题 + 平台 */
.row-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.item-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1a1a1a;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 16rpx;
}

.item-platform {
  font-size: 26rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
  font-weight: bold;
  color: #e67e22;
}

.item-platform.meituan {
  background: #fff3e0;
  color: #e67e22;
}

.item-platform.douyin {
  background: #fff1f0;
  color: #ff4b4b;
}

.item-platform.kuaishou {
  background: #fff8e1;
  color: #8b6914;
}

/* 第二行：券码 + 金额 + 状态 */
.row-detail {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.item-label {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.item-code {
  font-size: 24rpx;
  color: #666;
  font-family: 'Courier New', monospace;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-price {
  font-size: 28rpx;
  font-weight: 700;
  color: #f73f4c;
  flex-shrink: 0;
}

.item-status {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

.item-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.item-status.used {
  background: #e8f8ed;
  color: #5aab6e;
}

.item-status.cancelled {
  background: #f5f5f5;
  color: #999;
}

.item-status.refunded {
  background: #fff1f0;
  color: #f73f4c;
}

/* 第三行：商品ID + 时间 */
.row-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 8rpx;
  border-top: 1rpx solid #f5f5f5;
}

.item-shop-id {
  font-size: 24rpx;
  color: #b0b0b0;
}

.item-time {
  font-size: 24rpx;
  color: #b0b0b0;
}

/* 加载更多 */
.load-more,
.no-more {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  padding: 24rpx 0;
}

/* 空状态 */
.nodata {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  gap: 24rpx;
}

.nodata text {
  font-size: 28rpx;
  color: #999;
}
