page {
  background: #f5f7fa;
}

.container {
  padding: 20rpx 24rpx calc(140rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
  box-sizing: border-box;
}

/* 活动列表 */
.lottery-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

/* 活动卡片 */
.lottery-card {
  border-radius: 16rpx;
  padding: 10rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
  border: 2rpx solid transparent;
}

.lottery-card.card-pending {
  background: linear-gradient(135deg, #ffffff 0%, #ffffff 100%);
  border-color: #ffffff;
}

.lottery-card.card-drawn {
  background: linear-gradient(135deg, #ffffff 0%, #96f7b8 100%);
  border-color: #96f7b8;
}

.lottery-card:active {
  transform: translateY(2rpx);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.card-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.card-info {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.status-badge.status-pending {
  background: #01aeff;
  color: #ffffff;
}

.status-badge.status-drawn {
  background: #1cec68;
  color: #ffffff;
}

.meta-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

/* 分享按钮样式 - 紫色 */
.btn-share {
  color: #7c3aed;
  padding: 0rpx;
  background: #f3e8ff;
  border: 2rpx solid #d8b4fe;
  margin-top: 12rpx;  /* 与上方按钮间距 */
}

/* 修改操作区域为垂直布局 */
.card-action {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  /* gap: 12rpx;  按钮间距 */
}

.action-btn {
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 10rpx;
  border-radius: 28rpx;
  text-align: center;
  min-width: 120rpx;
  transition: all 0.2s;
}

.action-btn:active {
  opacity: 0.8;
  transform: scale(0.96);
}

.btn-edit {
  color: #0284c7;
  background: #e0f2fe;
  border: 2rpx solid #7dd3fc;
}

.btn-result {
  color: #16a34a;
  background: #dcfce7;
  border: 2rpx solid #86efac;
}

/* 底部悬浮新增按钮 */
.bottom-safe-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(245, 247, 250, 0.95) 0%, rgba(245, 247, 250, 0) 100%);
  pointer-events: none;
  z-index: 100;
}

.fab-container {
  display: flex;
  justify-content: center;
  pointer-events: auto;
  padding: 20rpx 0;
}

.fab-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  padding: 24rpx 52rpx;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 28rpx rgba(59, 130, 246, 0.35);
  transition: all 0.3s ease;
}

.fab-btn:active {
  transform: translateY(4rpx) scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.25);
}

.fab-icon {
  color: #fff;
  font-size: 36rpx;
  font-weight: 300;
  line-height: 1;
}

.fab-text {
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(15, 23, 42, 0.6);
  backdrop-filter: blur(8rpx);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.modal-content {
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  width: 100%;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
  animation: slideUp 0.3s ease;
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.15);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.result-modal {
  max-height: 75vh;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 2rpx solid #f1f5f9;
  position: relative;
}

.header-line {
  position: absolute;
  top: 16rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: #e2e8f0;
  border-radius: 3rpx;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
  flex: 1;
  text-align: center;
  margin: 0 60rpx;
}

.modal-close {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f1f5f9;
  border-radius: 50%;
  transition: all 0.2s;
}

.modal-close:active {
  background: #e2e8f0;
}

.close-icon {
  font-size: 36rpx;
  color: #64748b;
  line-height: 1;
  font-weight: 300;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
  max-height: 60vh;
}

.result-body {
  padding: 24rpx 32rpx;
}

/* 表单样式 - 单列布局 */
.form-section {
  margin-bottom: 32rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 28rpx;
  color: #1e293b;
  font-weight: 700;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #3b82f6;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  width: 90%;  /* 确保占满宽度 */
}
.form-item .tip{
  font-size: 22rpx;
  color: red;
}
.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #374151;
  font-weight: 600;
}

.form-label.required::after {
  content: '*';
  color: #ef4444;
  margin-left: 8rpx;
}

/* 输入框样式 - 修复padding问题 */
.form-input {
  height: 88rpx;
  line-height: 88rpx;  /* 垂直居中 */
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
 
  padding-left: 24rpx;   /* 左侧padding */
  padding-right: 24rpx;  /* 右侧padding - 明确设置 */
  font-size: 30rpx;
  color: #111827;
  box-sizing: border-box;  /* 边框盒模型，padding不增加总宽度 */
  width: 100%;             /* 宽度100% */
  display: block;          /* 块级显示 */
}

/* 日期选择器样式 */
.form-picker {
  height: 88rpx;
  line-height: 88rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;    /* 明确右侧padding */
  font-size: 30rpx;
  color: #111827;
  box-sizing: border-box;
  width: 100%;
  display: flex;
  align-items: center;
}

.form-picker.placeholder {
  color: #9ca3af;
}

/* 文本域样式 */
.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f9fafb;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;    /* 上下20，左右24 */
  font-size: 30rpx;
  color: #111827;
  box-sizing: border-box;
  display: block;
}

/* 输入框聚焦样式 */
.form-input:focus {
  border-color: #3b82f6;
  background: #fff;
  outline: none;           /* 移除默认outline */
}

/* 弹窗底部按钮 */
.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  border-top: 2rpx solid #f1f5f9;
  background: #fff;
}

.btn {
  flex: 1;
  height: 92rpx;
  line-height: 92rpx;
  text-align: center;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.btn-cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.btn-cancel:active {
  background: #e5e7eb;
}

.btn-confirm {
  background: linear-gradient(90deg, #3b82f6 0%, #8b5cf6 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
}

.btn-confirm:active {
  opacity: 0.9;
  transform: translateY(2rpx);
}

.btn-full {
  flex: 1;
}

/* 中奖结果列表 */
.result-stats {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-count {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.result-list {
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  overflow: hidden;
}

.result-header {
  display: flex;
  background: #f8fafc;
  padding: 20rpx 16rpx;
  border-bottom: 2rpx solid #e2e8f0;
}

.result-scroll {
  max-height: 400rpx;
}

.result-row {
  display: flex;
  padding: 20rpx 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
  align-items: center;
}

.result-row:last-child {
  border-bottom: none;
}

.col-rank {
  width: 140rpx;
  display: flex;
  justify-content: center;
}

.col-phone {
  flex: 1;
  text-align: center;
}

.col-action {
  width: 100rpx;
  display: flex;
  justify-content: center;
}

.rank-tag {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.rank-1 {
  background: linear-gradient(135deg, #fef3c7 0%, #fde68a 100%);
  color: #d97706;
}

.rank-2 {
  background: linear-gradient(135deg, #f3f4f6 0%, #e5e7eb 100%);
  color: #4b5563;
}

.rank-3 {
  background: linear-gradient(135deg, #ffedd5 0%, #fed7aa 100%);
  color: #c2410c;
}

.rank-4 {
  background: #f1f5f9;
  color: #64748b;
}

.phone-text {
  font-size: 28rpx;
  color: #334155;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.copy-tag {
  font-size: 22rpx;
  color: #3b82f6;
  background: #eff6ff;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
  transition: all 0.2s;
}

.copy-tag:active {
  background: #dbeafe;
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: 500;
}

.empty-mini {
  text-align: center;
  padding: 60rpx;
  color: #94a3b8;
  font-size: 26rpx;
}

.col-action {
  width: 180rpx;  /* 加宽以容纳两个按钮 */
  display: flex;
  flex-direction: column;  /* 垂直排列 */
  align-items: center;
  gap: 12rpx;
}

.verify-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
  transition: all 0.2s;
  min-width: 80rpx;
  text-align: center;
}

.verify-tag.unverified {
  color: #fff;
  background: #f59e0b;
  box-shadow: 0 2rpx 8rpx rgba(245, 158, 11, 0.3);
}

.verify-tag.unverified:active {
  background: #ffb868;
  transform: scale(0.95);
}

.verify-tag.verified {
  color: #22c55e;
  background: #f0fdf4;
  border: 1rpx solid #bbf7d0;
  cursor: default;
}