  color: var(--text-light);
}

.yd-bottom {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: var(--text-light);
}

/* ==================== 播控 ==================== */
.bokong-sheet {
  background: #fff;
}

.control-section {
  padding: 24rpx 32rpx 40rpx;
}

.ctrl-row {
  display: flex;
  justify-content: space-around;
  margin-bottom: 40rpx;
}

.ctrl-item {
  display: flex;
