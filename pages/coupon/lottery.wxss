page {
  background: linear-gradient(180deg, #ff4d4d 0%, #ff6b6b 30%, #fff5f5 50%, #f8f8f8 100%);
  min-height: 100vh;
}

.lottery-page {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* 顶部背景装饰 */
.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 400rpx;
  overflow: hidden;
  pointer-events: none;
}

.decoration-left,
.decoration-right {
  position: absolute;
  top: 20rpx;
  width: 120rpx;
  height: 120rpx;
  background: rgba(255, 215, 0, 0.3);
  border-radius: 50%;
}

.decoration-left {
  left: -40rpx;
}

.decoration-right {
  right: -40rpx;
}

/* 门店名称 */
.store-name {
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

/* 活动卡片 */
.activity-card {
  background: linear-gradient(135deg, #fff9e6 0%, #fff 50%, #fff9e6 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 77, 77, 0.15);
  border: 2rpx solid rgba(255, 215, 0, 0.3);
  position: relative;
  overflow: hidden;
}

.activity-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 215, 0, 0.1) 0%, transparent 50%);
  pointer-events: none;
}

.activity-title {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #d4380d;
  margin-bottom: 16rpx;
}

.title-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  border-radius: 50%;
  margin: 0 16rpx;
}

/* 开奖时间样式 - 突出显示 单行紧凑 */
.expire-time-box {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  padding: 16rpx 28rpx;
  background: linear-gradient(135deg, #ff4d4d 0%, #ff6b6b 100%);
  border-radius: 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 77, 77, 0.35);
}

.time-icon-simple {
  width: 28rpx;
  height: 28rpx;
  border: 3rpx solid #fff;
  border-radius: 50%;
  margin-right: 12rpx;
  position: relative;
}

.time-icon-simple::before {
  content: '';
  position: absolute;
  top: 4rpx;
  left: 50%;
  width: 3rpx;
  height: 10rpx;
  background: #fff;
  transform: translateX(-50%);
}

.time-icon-simple::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 3rpx;
  background: #fff;
  transform: translate(-20%, -50%);
}

.time-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.time-value {
  font-size: 28rpx;
  color: #fff;
  font-weight: bold;
  letter-spacing: 1rpx;
}

/* 奖品展示 */
.prizes-container {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.prize-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  text-align: center;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

/* 一等奖 - 金色边框，最突出 */
.prize-1 {
  border-color: #ffd700;
  background: linear-gradient(180deg, #fffbeb 0%, #fff 100%);
  box-shadow: 0 6rpx 20rpx rgba(255, 193, 7, 0.25);
}

/* 二等奖 - 橙色边框 */
.prize-2 {
  border-color: #ffb347;
  background: linear-gradient(180deg, #fff8f0 0%, #fff 100%);
  box-shadow: 0 4rpx 16rpx rgba(255, 149, 0, 0.15);
}

/* 三等奖 - 浅橙色边框 */
.prize-3 {
  border-color: #ffcc80;
  background: linear-gradient(180deg, #fffcf5 0%, #fff 100%);
  box-shadow: 0 4rpx 12rpx rgba(255, 204, 128, 0.15);
}

/* 保底奖 - 灰色边框，最普通 */
.prize-4 {
  border-color: #e0e0e0;
  background: linear-gradient(180deg, #fafafa 0%, #fff 100%);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.prize-badge {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

/* 一等奖 - 红色 */
.badge-1 {
  background: #e53935;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.4);
  font-size: 26rpx;
}

/* 二等奖 - 橙色 */
.badge-2 {
  background: #ff9800;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.4);
}

/* 三等奖 - 蓝色 */
.badge-3 {
  background: #2196f3;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(33, 150, 243, 0.4);
}

/* 保底奖 - 灰色 */
.badge-4 {
  background: #9e9e9e;
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(158, 158, 158, 0.4);
}

.prize-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  word-break: break-all;
}

/* 保底奖提示 */
.guarantee-tip {
  text-align: center;
  margin-top: 24rpx;
  padding: 16rpx 24rpx;
  background: linear-gradient(135deg, #fff5e6 0%, #ffe8cc 100%);
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #d48806;
  border: 2rpx dashed #ffc53d;
}

.guarantee-tip .highlight {
  color: #ff4d4d;
  font-weight: bold;
  font-size: 32rpx;
  margin: 0 8rpx;
}

/* 活动规则卡片 */
.rules-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.rules-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.rules-icon {
  width: 8rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #ff4d4d 0%, #ff6b6b 100%);
  border-radius: 4rpx;
  margin-right: 16rpx;
}

.rules-content {
  padding: 8rpx 0;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 20rpx;
  font-size: 26rpx;
  line-height: 1.6;
}

.rule-item:last-child {
  margin-bottom: 0;
}

.rule-number {
  width: 36rpx;
  height: 36rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff4d4d 100%);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  /* padding-top: 6rpx; */
}

.rule-label {
  color: #666;
  flex-shrink: 0;
}

.rule-value {
  color: #333;
  font-weight: 500;
}

.remark-item .rule-text {
  flex-direction: column;
  align-items: flex-start;
}

.remark-value {
  color: #666 !important;
  font-weight: normal !important;
  margin-top: 6rpx;
  padding: 12rpx 16rpx;
  background: #f9f9f9;
  border-radius: 8rpx;
  border-left: 4rpx solid #ff6b6b;
  width: 100%;
  box-sizing: border-box;
}

/* 常驻提示样式 - 红色醒目风格 */
.rules-highlight-tip {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  background: linear-gradient(135deg, #ff4d4d 0%, #ff6b6b 100%);
  border-radius: 12rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 77, 77, 0.3);
}

.rules-highlight-tip .tip-star {
  font-size: 28rpx;
  color: #ffd700;
  margin-right: 12rpx;
  flex-shrink: 0;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.rules-highlight-tip .tip-text {
  flex: 1;
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
  line-height: 1.5;
}

/* 用户状态卡片 */
.user-status-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.status-content {
  text-align: center;
}

.join-btn {
  background: linear-gradient(135deg, #ff4d4d 0%, #ff6b6b 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 80rpx;
  border-radius: 50rpx;
  display: inline-block;
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 77, 0.4);
  transition: all 0.3s ease;
}

.join-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(255, 77, 77, 0.4);
}

.join-tip {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.ended-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #999;
  font-size: 28rpx;
}

.ended-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e0e0e0 0%, #bdbdbd 100%);
  border-radius: 50%;
  margin-bottom: 16rpx;
  position: relative;
}

.ended-icon::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 40rpx;
  color: #fff;
}

/* 已参与状态 */
.status-content.joined {
  padding: 16rpx 0;
}

.joined-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #52c41a 0%, #73d13d 100%);
  border-radius: 50%;
  margin: 0 auto 16rpx;
  position: relative;
}

.joined-icon::after {
  content: '✓';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 44rpx;
  color: #fff;
}

.joined-text {
  font-size: 30rpx;
  color: #52c41a;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.win-count {
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  display: inline-block;
  margin-bottom: 12rpx;
}

.count-label {
  font-size: 26rpx;
  color: #666;
}

.count-value {
  font-size: 32rpx;
  color: #fa8c16;
  font-weight: bold;
}

.waiting-tip {
  font-size: 24rpx;
  color: #999;
  animation: blink 1.5s infinite;
}

@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 中奖结果 */
.win-result,
.no-win-result {
  padding: 16rpx 0;
}

.win-result .tip {
  margin-top: 5rpx;
  font-size: 26rpx;
  color: #999;
}

.win-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffaa00 100%);
  border-radius: 50%;
  margin: 0 auto 20rpx;
  position: relative;
  animation: pulse 2s infinite;
}

.win-icon::after {
  content: '🎉';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.win-text {
  font-size: 34rpx;
  color: #d4380d;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.win-prize {
  display: inline-block;
  padding: 12rpx 40rpx;
  border-radius: 8rpx;
  font-size: 30rpx;
  font-weight: bold;
}

/* 中奖等级颜色 - 纯色白字 */
.prize-level-1 {
  background: #e53935;
  color: #fff;
}

.prize-level-2 {
  background: #ff9800;
  color: #fff;
}

.prize-level-3 {
  background: #2196f3;
  color: #fff;
}

.prize-level-4 {
  background: #9e9e9e;
  color: #fff;
}

.no-win-icon {
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #f0f0f0 0%, #d9d9d9 100%);
  border-radius: 50%;
  margin: 0 auto 20rpx;
  position: relative;
}

.no-win-icon::after {
  content: '😔';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
}

.no-win-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.no-win-tip {
  font-size: 24rpx;
  color: #999;
}

/* 排行榜 */
.rank-card {
  background: linear-gradient(180deg, #fff9e6 0%, #fff 20%);
  border-radius: 24rpx;
  padding: 0;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid rgba(255, 215, 0, 0.2);
}

.rank-header {
  background: linear-gradient(135deg, #ff4d4d 0%, #ff6b6b 100%);
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.rank-title-decoration {
  width: 60rpx;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 2rpx;
}

.rank-title-decoration.left {
  margin-right: 24rpx;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.8));
}

.rank-title-decoration.right {
  margin-left: 24rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.8), transparent);
}

.rank-table-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(180deg, #fff5e6 0%, #fff 100%);
  font-size: 24rpx;
  color: #999;
  font-weight: 500;
  border-bottom: 2rpx solid #f5f5f5;
}

.rank-table-header .col-rank {
  width: 100rpx;
  text-align: center;
}

.rank-table-header .col-mobile {
  flex: 1;
  text-align: center;
}

.rank-table-header .col-count,
.rank-table-header .col-prize {
  width: 160rpx;
  text-align: center;
}

.rank-list {
  padding: 0 24rpx 24rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-item .col-rank {
  width: 100rpx;
  display: flex;
  justify-content: center;
}

.rank-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
}

/* 排行榜前三名 - 纯色白字 */
.rank-1 {
  background: #e53935;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(229, 57, 53, 0.4);
  font-weight: bold;
}

.rank-2 {
  background: #ff9800;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(255, 152, 0, 0.4);
}

.rank-3 {
  background: #2196f3;
  color: #fff;
  box-shadow: 0 4rpx 10rpx rgba(33, 150, 243, 0.4);
}

.rank-normal {
  background: #f5f5f5;
  color: #999;
}

.rank-item .col-mobile {
  flex: 1;
  text-align: center;
  font-size: 28rpx;
  color: #333;
}

.rank-item .col-count {
  width: 160rpx;
  text-align: center;
}

.count-text {
  font-size: 26rpx;
  color: #fa8c16;
  font-weight: 500;
}

.rank-item .col-prize {
  width: 160rpx;
  text-align: center;
}

.prize-result {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.prize-win {
  color: #fff;
}

.prize-none {
  background: #f5f5f5;
  color: #999;
}

/* 空状态 */
.empty-list {
  padding: 60rpx 0;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: #f5f5f5;
  border-radius: 50%;
  margin: 0 auto 20rpx;
  position: relative;
}

.empty-icon::after {
  content: '📋';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 48rpx;
}

/* 底部提示 */
.footer-tip {
  text-align: center;
  font-size: 22rpx;
  color: rgb(90, 90, 90);
  padding: 24rpx 0;
}
